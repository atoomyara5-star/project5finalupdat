@using Microsoft.AspNetCore.Http
@{
    var userName = Context.Session.GetString("UserName");
    var role = Context.Session.GetString("Role");
    var email = Context.Session.GetString("Email");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Library System - @ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* شريط التنقل */
        .navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 15px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.8rem;
            color: white !important;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .navbar-brand i {
                font-size: 2.2rem;
                color: #4e73df;
                background: rgba(255,255,255,0.1);
                padding: 8px;
                border-radius: 12px;
            }

            .navbar-brand span {
                background: linear-gradient(135deg, #fff, #e0e0e0);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                font-weight: 700;
            }

        .nav-link {
            color: rgba(255,255,255,0.8) !important;
            font-weight: 500;
            padding: 10px 20px !important;
            border-radius: 10px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0 2px;
        }

            .nav-link i {
                font-size: 1.2rem;
            }

            .nav-link:hover {
                background: linear-gradient(90deg, #4e73df, #224abe);
                color: white !important;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(78, 115, 223, 0.3);
            }

            .nav-link.active {
                background: linear-gradient(90deg, #4e73df, #224abe);
                color: white !important;
            }

        .dropdown-menu {
            border: none;
            box-shadow: 0 5px 25px rgba(0,0,0,0.15);
            border-radius: 15px;
            padding: 10px;
            margin-top: 10px;
            border: 1px solid rgba(78, 115, 223, 0.1);
        }

        .dropdown-item {
            padding: 12px 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s;
            font-weight: 500;
        }

            .dropdown-item i {
                width: 22px;
                color: #4e73df;
                font-size: 1.1rem;
            }

            .dropdown-item:hover {
                background: linear-gradient(90deg, #4e73df, #224abe);
                color: white !important;
                transform: translateX(5px);
            }

                .dropdown-item:hover i {
                    color: white;
                }

        .dropdown-divider {
            margin: 8px 0;
            border-color: rgba(78, 115, 223, 0.1);
        }

        /* المحتوى الرئيسي */
        .main-content {
            flex: 1;
            padding: 40px 0;
            animation: fadeIn 0.5s ease-in;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* الفوتر */
        footer {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            margin-top: auto;
            padding: 50px 0 20px;
            position: relative;
        }

            footer::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, #4e73df, #1cc88a, #36b9cc);
            }

            footer h5 {
                font-weight: 700;
                margin-bottom: 25px;
                display: flex;
                align-items: center;
                gap: 10px;
                color: #fff;
                font-size: 1.2rem;
            }

                footer h5 i {
                    color: #4e73df;
                    font-size: 1.4rem;
                }

            footer ul {
                list-style: none;
                padding: 0;
            }

                footer ul li {
                    margin-bottom: 15px;
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    color: rgba(255,255,255,0.7);
                    transition: all 0.2s;
                }

                    footer ul li i {
                        width: 20px;
                        color: #4e73df;
                        font-size: 1rem;
                    }

                    footer ul li a {
                        color: rgba(255,255,255,0.7);
                        text-decoration: none;
                        transition: all 0.2s;
                    }

                        footer ul li a:hover {
                            color: white;
                            transform: translateX(5px);
                        }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            margin-top: 30px;
            border-top: 1px solid rgba(255,255,255,0.1);
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
        }

            .footer-bottom i {
                color: #e74a3b;
                animation: heartbeat 1.5s ease-in-out infinite;
            }

        @@keyframes heartbeat {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }

        /* بطاقات الكتب */
        .book-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: all 0.3s;
            height: 100%;
            border: 1px solid rgba(78, 115, 223, 0.1);
        }

            .book-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 8px 25px rgba(78, 115, 223, 0.2);
            }

            .book-card .card-img-top {
                height: 250px;
                object-fit: cover;
            }

            .book-card .card-body {
                padding: 20px;
            }

            .book-card .card-title {
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 10px;
            }

            .book-card .card-text {
                color: #666;
                font-size: 0.9rem;
                margin-bottom: 15px;
            }

        /* أزرار مخصصة */
        .btn-primary {
            background: linear-gradient(135deg, #4e73df, #224abe);
            border: none;
            padding: 10px 25px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(78, 115, 223, 0.2);
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(78, 115, 223, 0.3);
            }

        .btn-outline-primary {
            border: 2px solid #4e73df;
            color: #4e73df;
            padding: 8px 20px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

            .btn-outline-primary:hover {
                background: linear-gradient(135deg, #4e73df, #224abe);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(78, 115, 223, 0.2);
            }

        /* تنسيق البحث */
        .search-box {
            background: white;
            border-radius: 50px;
            padding: 5px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid rgba(78, 115, 223, 0.1);
        }

            .search-box input {
                border: none;
                padding: 12px 20px;
                border-radius: 50px 0 0 50px;
                background: transparent;
            }

                .search-box input:focus {
                    outline: none;
                    box-shadow: none;
                }

            .search-box button {
                border-radius: 50px;
                padding: 10px 30px;
                background: linear-gradient(135deg, #4e73df, #224abe);
                border: none;
                color: white;
                font-weight: 600;
            }

                .search-box button:hover {
                    transform: scale(0.98);
                }

        /* تنسيق التنبيهات */
        .alert {
            border-radius: 15px;
            border: none;
            padding: 15px 20px;
            margin-bottom: 20px;
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .alert-success {
            background: linear-gradient(135deg, #1cc88a, #169b6b);
            color: white;
        }

        .alert-danger {
            background: linear-gradient(135deg, #e74a3b, #c0392b);
            color: white;
        }

        .alert-info {
            background: linear-gradient(135deg, #36b9cc, #258391);
            color: white;
        }

        /* تنسيق عداد الإشعارات */
        .notification-badge {
            position: absolute;
            top: 0;
            right: 0;
            transform: translate(25%, -25%);
            background-color: #e74a3b;
            color: white;
            border-radius: 50%;
            padding: 3px 6px;
            font-size: 0.6rem;
            font-weight: 600;
            min-width: 18px;
            text-align: center;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                transform: translate(25%, -25%) scale(1);
            }

            50% {
                transform: translate(25%, -25%) scale(1.1);
            }

            100% {
                transform: translate(25%, -25%) scale(1);
            }
        }
    </style>
</head>
<body>
    <!-- شريط التنقل -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half"></i>
                <span>Library</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (userName != null)
                {
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door-fill"></i>
                                <span class="d-none d-lg-inline">Home</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Books" ? "active" : "")"
                               asp-controller="Books" asp-action="Index">
                                <i class="bi bi-book-fill"></i>
                                <span class="d-none d-lg-inline">Books</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Rooms" ? "active" : "")"
                               asp-controller="Rooms" asp-action="Index">
                                <i class="bi bi-door-open-fill"></i>
                                <span class="d-none d-lg-inline">Rooms</span>
                            </a>
                        </li>
                        <li class="nav-item position-relative">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notifications" ? "active" : "")"
                               asp-controller="Notifications" asp-action="Index">
                                <i class="bi bi-bell-fill"></i>
                                <span class="d-none d-lg-inline">Notifications</span>
                                <span id="notificationBadge" class="notification-badge" style="display: none;">0</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Feedback" ? "active" : "")"
                               asp-controller="Feedback" asp-action="Submit">
                                <i class="bi bi-chat-dots-fill"></i>
                                <span class="d-none d-lg-inline">Feedback</span>
                            </a>
                        </li>
                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-grid-fill"></i>
                                    <span class="d-none d-lg-inline">Admin Panel</span>
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span class="d-none d-lg-inline">@userName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person"></i>
                                        My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Books" asp-action="MyBorrows">
                                        <i class="bi bi-book"></i>
                                        My Borrows
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Rooms" asp-action="MyReservations">
                                        <i class="bi bi-calendar-check"></i>
                                        My Reservations
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Feedback" asp-action="Submit">
                                        <i class="bi bi-chat-dots"></i>
                                        Send Feedback
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i>
                                        Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="SignUp">
                                <i class="bi bi-person-plus"></i>
                                Sign Up
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <!-- المحتوى الرئيسي -->
    <div class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <!-- الفوتر -->
    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5>
                        <i class="bi bi-book-half"></i>
                        Library System
                    </h5>
                    <p class="text-white-50 small">
                        A modern university library system for books, rooms, reservations, and student services.
                        Your gateway to knowledge and learning.
                    </p>
                    <div class="mt-3">
                        <span class="badge bg-primary me-2">v2.0</span>
                        <span class="badge bg-success">Updated 2026</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <h5>
                        <i class="bi bi-link"></i>
                        Quick Links
                    </h5>
                    <ul>
                        <li>
                            <i class="bi bi-chevron-right"></i>
                            <a asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li>
                            <i class="bi bi-chevron-right"></i>
                            <a asp-controller="Books" asp-action="Index">Books Catalog</a>
                        </li>
                        <li>
                            <i class="bi bi-chevron-right"></i>
                            <a asp-controller="Rooms" asp-action="Index">Study Rooms</a>
                        </li>
                        <li>
                            <i class="bi bi-chevron-right"></i>
                            <a asp-controller="Feedback" asp-action="Submit">Send Feedback</a>
                        </li>
                       
                    </ul>
                </div>

                <div class="col-md-4">
                    <h5>
                        <i class="bi bi-envelope-fill"></i>
                        Contact Us
                    </h5>
                    <ul>
                        <li>
                            <i class="bi bi-geo-alt-fill"></i>
                            Yarmouk University - Jordan
                        </li>
                        <li>
                            <i class="bi bi-envelope-fill"></i>
                            library@yu.edu.jo
                        </li>
                        <li>
                            <i class="bi bi-telephone-fill"></i>
                            +962 2 7211111
                        </li>
                        <li>
                            <i class="bi bi-clock-fill"></i>
                            Sun - Thu: 8:00 AM - 8:00 PM
                        </li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <small>
                    © 2026 Library Management System | Developed with
                    <i class="bi bi-heart-fill text-danger"></i>
                    by <strong>Yara Atoom</strong>
                </small>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // تحديث عداد الإشعارات
        function updateNotificationCount() {
            fetch('/Notifications/GetUnreadCount')
                .then(response => response.json())
                .then(data => {
                    const badge = document.getElementById('notificationBadge');
                    if (data.count > 0) {
                        badge.textContent = data.count;
                        badge.style.display = 'inline';
                    } else {
                        badge.style.display = 'none';
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        // تحديث كل 30 ثانية
        setInterval(updateNotificationCount, 30000);

        // تحديث عند تحميل الصفحة
        document.addEventListener('DOMContentLoaded', updateNotificationCount);

        // تفعيل التولتيب
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // تفعيل البوبوفر
        var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'))
        var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
            return new bootstrap.Popover(popoverTriggerEl)
        });

        // إغلاق التنبيهات تلقائياً بعد 5 ثواني
        setTimeout(function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);

        // إضافة كلاس active للرابط الحالي
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            document.querySelectorAll('.nav-link').forEach(function(link) {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active'); 
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>