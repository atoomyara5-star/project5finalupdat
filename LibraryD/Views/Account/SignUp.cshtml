@model User
@{
    ViewData["Title"] = "Sign Up";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card p-4 shadow-lg border-0 rounded-4">
            <div class="text-center mb-4">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex p-3 mb-3">
                    <i class="bi bi-person-plus-fill text-success" style="font-size: 2.5rem;"></i>
                </div>
                <h2 class="fw-bold">Create Account</h2>
                <p class="text-muted">Join our library community</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post" asp-action="SignUp" id="signupForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label fw-bold">First Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-person-fill text-primary"></i></span>
                            <input asp-for="FirstName" class="form-control bg-light border-0"
                                   placeholder="Enter first name" required />
                        </div>
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label fw-bold">Last Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-person-fill text-primary"></i></span>
                            <input asp-for="LastName" class="form-control bg-light border-0"
                                   placeholder="Enter last name" required />
                        </div>
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-envelope-fill text-primary"></i></span>
                        <input asp-for="Email" type="email" class="form-control bg-light border-0"
                               placeholder="Enter university email" required
                               pattern=".+@@ses\.yu\.edu\.jo$"
                               title="Please use your university email (@@ses.yu.edu.jo)" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i> Must be @@ses.yu.edu.jo email
                    </small>
                    <div id="emailValidationMessage" class="mt-2"></div>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-bold">Phone Number</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-telephone-fill text-primary"></i></span>
                        <input asp-for="Phone" class="form-control bg-light border-0"
                               placeholder="Enter phone number (optional)" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-bold">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-lock-fill text-primary"></i></span>
                        <input asp-for="Password" type="password" id="password" class="form-control bg-light border-0"
                               placeholder="Enter password" required minlength="6" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                    <small class="text-muted">
                        <i class="bi bi-info-circle"></i> Minimum 6 characters
                    </small>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-lock-fill text-primary"></i></span>
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control bg-light border-0"
                               placeholder="Confirm password" required minlength="6" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confirmPassword', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div id="passwordMatchMessage" class="mt-2"></div>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="termsCheck" required>
                        <label class="form-check-label" for="termsCheck">
                            I agree to the <a href="#" class="text-decoration-none">Terms of Service</a> and
                            <a href="#" class="text-decoration-none">Privacy Policy</a>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100 py-2 mb-3" id="submitBtn">
                    <i class="bi bi-person-plus me-2"></i> Create Account
                </button>
            </form>

            <hr class="my-4">

            <div class="text-center">
                <p class="mb-0">
                    Already have an account?
                    <a asp-action="Login" class="text-decoration-none fw-bold">
                        <i class="bi bi-box-arrow-in-right"></i> Login
                    </a>
                </p>
            </div>
        </div>

        <!-- معلومات إضافية -->
        <div class="card mt-3 bg-light border-0">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <i class="bi bi-shield-check text-primary fs-4 me-3"></i>
                    <div>
                        <h6 class="mb-1">Secure Registration</h6>
                        <p class="small text-muted mb-0">
                            Your information is encrypted and secure. We'll never share your data.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: all 0.3s;
        border: none !important;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(78, 115, 223, 0.2) !important;
        }

    .input-group-text {
        border-radius: 10px 0 0 10px;
        background-color: #f8f9fc !important;
    }

    .form-control {
        border-radius: 0 10px 10px 0;
        background-color: #f8f9fc !important;
        border: none !important;
    }

        .form-control:focus {
            box-shadow: none;
            background-color: #ffffff !important;
            outline: 2px solid #4e73df;
        }

    .btn-outline-secondary {
        border-radius: 0 10px 10px 0;
        border: none;
        background-color: #f8f9fc;
    }

        .btn-outline-secondary:hover {
            background-color: #e9ecef;
        }

    .btn-success {
        background: linear-gradient(135deg, #1cc88a, #169b6b);
        border: none;
        transition: all 0.3s;
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(28, 200, 138, 0.4);
        }

    .form-check-input:checked {
        background-color: #1cc88a;
        border-color: #1cc88a;
    }
</style>

<script>
    // التحقق من صحة الإيميل الجامعي
    document.getElementById('Email').addEventListener('input', function() {
        var email = this.value;
        var messageDiv = document.getElementById('emailValidationMessage');

        if (email.length > 0) {
            if (email.endsWith('@@ses.yu.edu.jo')) {
                messageDiv.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill"></i> Valid university email</span>';
            } else {
                messageDiv.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle-fill"></i> Please use your university email (@@ses.yu.edu.jo)</span>';
            }
        } else {
            messageDiv.innerHTML = '';
        }
    });

    // التحقق من تطابق كلمة المرور
    document.getElementById('confirmPassword').addEventListener('input', function() {
        var newPass = document.getElementById('password').value;
        var confirmPass = this.value;
        var messageDiv = document.getElementById('passwordMatchMessage');
        var submitBtn = document.getElementById('submitBtn');

        if (confirmPass.length > 0) {
            if (newPass === confirmPass) {
                messageDiv.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill"></i> Passwords match</span>';
                submitBtn.disabled = false;
            } else {
                messageDiv.innerHTML = '<span class="text-danger"><i class="bi bi-exclamation-circle-fill"></i> Passwords do not match</span>';
                submitBtn.disabled = true;
            }
        } else {
            messageDiv.innerHTML = '';
            submitBtn.disabled = false;
        }
    });

    // إظهار/إخفاء كلمة المرور
    function togglePassword(inputId, btn) {
        var input = document.getElementById(inputId);
        var icon = btn.querySelector('i');

        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('bi-eye');
            icon.classList.add('bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('bi-eye-slash');
            icon.classList.add('bi-eye');
        }
    }

    // منع إرسال النموذج إذا كانت كلمة المرور غير متطابقة
    document.getElementById('signupForm').addEventListener('submit', function(e) {
        var password = document.getElementById('password').value;
        var confirmPassword = document.getElementById('confirmPassword').value;

        if (password !== confirmPassword) {
            e.preventDefault();
            alert('❌ Passwords do not match!');
        }
    });

    // التحقق من قوة كلمة المرور
    document.getElementById('password').addEventListener('input', function() {
        var password = this.value;
        var strengthMessage = document.getElementById('passwordStrength');

        if (!strengthMessage) {
            strengthMessage = document.createElement('div');
            strengthMessage.id = 'passwordStrength';
            this.parentElement.parentElement.appendChild(strengthMessage);
        }

        if (password.length > 0) {
            var strength = 'Weak';
            var color = 'text-danger';

            if (password.length >= 8 && /[A-Z]/.test(password) && /[0-9]/.test(password) && /[^A-Za-z0-9]/.test(password)) {
                strength = 'Strong';
                color = 'text-success';
            } else if (password.length >= 6 && (/[A-Z]/.test(password) || /[0-9]/.test(password))) {
                strength = 'Medium';
                color = 'text-warning';
            }

            strengthMessage.innerHTML = `<span class="${color}"><i class="bi bi-shield"></i> Password strength: ${strength}</span>`;
        } else {
            strengthMessage.innerHTML = '';
        }
    });
</script>