@model IEnumerable<LibraryD.Models.Feedback>

@{
    ViewData["Title"] = "Student Feedbacks";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <!-- عنوان الصفحة مع بطاقة احترافية -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-gradient-primary">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="mb-1 text-white">
                                <i class="bi bi-chat-dots-fill me-2"></i>
                                Student Feedbacks
                            </h2>
                            <p class="mb-0 text-white-50">
                                <i class="bi bi-envelope-paper me-1"></i>
                                Manage and review all feedback messages from students
                            </p>
                        </div>
                        <div>
                            <span class="badge bg-white text-primary p-3 rounded-circle shadow-sm">
                                <i class="bi bi-chat-dots fs-3"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- بطاقة عرض الفيدباك -->
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary">
                    <i class="bi bi-list-ul me-2"></i>
                    All Feedback Messages
                </h5>
                <div class="text-muted">
                    <i class="bi bi-envelope me-1"></i>
                    Total: @Model.Count()
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            @if (!Model.Any())
            {
                <div class="alert alert-info d-flex align-items-center border-0" role="alert">
                    <i class="bi bi-info-circle-fill me-2 fs-4"></i>
                    <div>
                        No feedback messages found. When students send feedback, they will appear here.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="feedbackTable">
                        <thead class="table-light">
                            <tr>
                                <th width="60">#</th>
                                <th width="250">Student</th>
                                <th>Message</th>
                                <th width="180">Date & Time</th>
                                <th width="120" class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">@i</td>

                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-primary bg-opacity-10 text-primary me-2">
                                                @(item.User?.FirstName?.Length > 0 ? item.User.FirstName.Substring(0, 1).ToUpper() : "U")
                                            </div>
                                            <div>
                                                <div class="fw-bold">
                                                    @(item.User != null
                                                                                                ? item.User.FirstName + " " + item.User.LastName
                                                                                                : "Unknown Student")
                                        </div>
                                        <small class="text-muted">
                                            <i class="bi bi-envelope me-1 small"></i>
                                            @(item.User?.Email ?? "N/A")
                                        </small>
                                    </div>
                                </div>
                            </td>

                                    <td>
                                        <div class="feedback-message p-3 bg-light rounded">
                                            <i class="bi bi-quote text-primary me-1"></i>
                                            "@item.Message"
                                        </div>
                                    </td>

                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-calendar3 text-primary me-2"></i>
                                            <div>
                                                <div class="fw-bold small">
                                                    @(item.Date?.ToString("dd/MM/yyyy") ?? "N/A")
                                                </div>
                                                <small class="text-muted">
                                                    @(item.Date?.ToString("HH:mm") ?? "")
                                                </small>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <form asp-action="Delete"
                                              asp-route-id="@item.FeedbackId"
                                              method="post"
                                              onsubmit="return confirm('⚠️ Are you sure you want to delete this feedback? This action cannot be undone.');">

                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete Feedback">
                                                <i class="bi bi-trash-fill me-1"></i>
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- ستايلات إضافية -->
<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 18px;
    }

    .feedback-message {
        max-width: 450px;
        border-left: 4px solid #4e73df;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #333;
        word-wrap: break-word;
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(78, 115, 223, 0.05);
    }

    .btn-outline-danger {
        border-width: 2px;
        transition: all 0.3s;
    }

        .btn-outline-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(220, 53, 69, 0.2);
        }

    /* تحسين المظهر على الجوال */
    @@media (max-width: 768px) {
        .feedback-message {
            max-width: 200px;
        }

        .avatar-circle {
            width: 35px;
            height: 35px;
            font-size: 16px;
        }
    }

    /* تخصيص شريط التمرير */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb {
        background: #4e73df;
        border-radius: 10px;
    }

        ::-webkit-scrollbar-thumb:hover {
            background: #224abe;
        }
</style>