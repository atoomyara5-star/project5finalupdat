@model LibraryD.Models.User

@{
    ViewData["Title"] = "My Profile";
    Layout = "_Layout";

}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-white">My Profile</h2>
        <p class="text-white-50">View your account information and activity</p>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="bi bi-person-circle" style="font-size: 5rem; color: #667eea;"></i>
                </div>
                <h4>@Model.FirstName @Model.LastName</h4>
                <p class="text-muted">@Model.Email</p>
                <p class="text-muted">@Model.Phone</p>
                <span class="badge @(Model.Role == "Admin" ? "bg-danger" : "bg-info")">
                    @Model.Role
                </span>

                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-primary">
                        Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">

        <!-- Borrowed Books -->
        <div class="card mb-4 shadow">
            <div class="card-header">
                <h5 class="mb-0">My Borrowed Books</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Borrow Date</th>
                                <th>Return Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var borrow in Model.Borrowings)
                            {
                                <tr>
                                    <td>@borrow.Book?.BookName</td>

                                    <!-- FIXED DATE -->
                                    <td>@($"{borrow.BorrowDate:yyyy-MM-dd}")</td>

                                    <!-- FIXED RETURN DATE -->
                                    <td>
                                        @(borrow.ReturnDate != null
                                                                            ? $"{borrow.ReturnDate:yyyy-MM-dd}"
                                                                            : "-")
                                </td>

                                    <td>
                                    @{
                                            string statusClass =
                                            borrow.StatusId == 2 ? "bg-success" :
                                            borrow.StatusId == 4 ? "bg-secondary" :
                                            "bg-warning";

                                            string statusText =
                                            borrow.StatusId == 2 ? "Borrowed" :
                                            borrow.StatusId == 4 ? "Returned" :
                                            "Pending";
                                        }

                                        <span class="badge @statusClass">
                                            @statusText
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Borrowings.Any())
                {
                    <p class="text-muted text-center">No borrowed books</p>
                }
            </div>
        </div>

        <!-- Room Reservations -->
        <div class="card shadow">
            <div class="card-header">
                <h5 class="mb-0">My Room Reservations</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Room</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var res in Model.RoomReservations)
                            {
                                <tr>
                                    <td>@res.Room?.RoomName</td>

                                    <!-- FIXED DATE -->
                                    <td>@($"{res.ReservationDate:yyyy-MM-dd}")</td>

                                    <!-- FIXED TIME -->
                                    <td>
                                        @($"{res.StartTime:HH:mm}") -
                                        @($"{res.EndTime:HH:mm}")
                                    </td>

                                    <td>
                                        @{
                                            string statusClass =
                                            res.StatusId == 2 ? "bg-success" :
                                            res.StatusId == 3 ? "bg-danger" :
                                            "bg-warning";

                                            string statusText =
                                            res.StatusId == 2 ? "Approved" :
                                            res.StatusId == 3 ? "Rejected" :
                                            "Pending";
                                        }

                                        <span class="badge @statusClass">
                                            @statusText
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody> 
                    </table>
                </div>

                @if (!Model.RoomReservations.Any())
                {
                    <p class="text-muted text-center">No room reservations</p>
                }
            </div>
        </div>

    </div>
</div>
