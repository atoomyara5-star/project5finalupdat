@model LibraryD.Models.Room
@{
    ViewData["Title"] = "Add Room";
    Layout = "_AdminLayout";
}

<div class="card p-4 shadow-sm">
    <h2 class="mb-4">
        <i class="bi bi-plus-circle-fill text-primary me-2"></i>
        Add New Study Room
    </h2>

    <form method="post" asp-action="AddRoom">
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="RoomName" class="form-label fw-bold">
                        <i class="bi bi-door-open me-1"></i> Room Name
                    </label>
                    <input asp-for="RoomName" class="form-control" required placeholder="e.g., Study Room A101" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Capacity" class="form-label fw-bold">
                        <i class="bi bi-people-fill me-1"></i> Capacity
                    </label>
                    <input asp-for="Capacity" type="number" class="form-control" required placeholder="Number of seats" />
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="StatusId" class="form-label fw-bold">
                <i class="bi bi-info-circle me-1"></i> Status
            </label>
            <select asp-for="StatusId" class="form-select" asp-items="ViewBag.Statuses">
                <option value="1" selected>Available</option>
            </select>
            <small class="text-muted">Default is "Available"</small>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save"></i> Add Room
            </button>
            <a asp-action="RoomsList" class="btn btn-secondary px-4">
                <i class="bi bi-x-circle"></i> Cancel
            </a>
        </div>
    </form>
</div>

<style> 
    .form-control:focus, .form-select:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
    }
</style>