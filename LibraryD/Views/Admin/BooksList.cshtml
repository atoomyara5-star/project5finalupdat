@model IEnumerable<LibraryD.Models.Book>
@{
    ViewData["Title"] = "Books List";
    Layout = "_AdminLayout";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="text-white">Books List</h2>
        <p class="text-white-50">Manage library books</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="AddBook" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Book
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>  <!-- تأكد من وجود هذا العمود -->
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.BookId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(book.Picture))
                                {
                                    <img src="@book.Picture"
                                         alt="Book Image"
                                         style="max-height: 60px; width: auto; object-fit: cover;"
                                         class="img-thumbnail"
                                         onerror="this.src='https://via.placeholder.com/60?text=No+Image'" />
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/60?text=No+Image"
                                         alt="No Image"
                                         class="img-thumbnail" />
                                }
                            </td>
                            <td><strong>@book.BookName</strong></td>
                            <td>@book.Author</td>
                            <td>@book.Category?.CategoryName</td>
                            <td>
                                <span class="badge @(book.Status?.StatusName == "Available" ? "bg-success" : "bg-danger")">
                                    @book.Status?.StatusName
                                </span>
                            </td>
                            <td>
                                <a asp-action="EditBook" asp-route-id="@book.BookId" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" asp-action="DeleteBook" asp-route-id="@book.BookId"
                                      onsubmit="return confirm('Are you sure you want to delete this book?');" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>