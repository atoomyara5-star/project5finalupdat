@model IEnumerable<LibraryD.Models.Room>
@{
    ViewData["Title"] = "Rooms List";
    Layout = "_AdminLayout";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="text-white">Rooms Management</h2>
        <p class="text-white-50">Manage study rooms and their availability</p>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="AddRoom" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Room
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Room Name</th>
                        <th>Capacity</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var room in Model)
                    {
                        <tr>
                            <td>@room.RoomId</td>
                            <td>
                                <i class="bi bi-door-open text-primary me-2"></i>
                                <strong>@room.RoomName</strong>
                            </td>
                            <td>
                                <i class="bi bi-people-fill me-1"></i>
                                @room.Capacity people
                            </td>
                            <td>
                                @{
                                    string statusClass = room.StatusId == 1 ? "bg-success" : "bg-secondary";
                                    string statusText = room.StatusId == 1 ? "Available" : "Unavailable";
                                }
                                <span class="badge @statusClass">
                                    <i class="bi @(room.StatusId == 1 ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                    @statusText
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="EditRoom" asp-route-id="@room.RoomId" class="btn btn-warning btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form method="post" asp-action="DeleteRoom" asp-route-id="@room.RoomId"
                                      onsubmit="return confirm('Are you sure you want to delete this room?');" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-door-open" style="font-size: 4rem; color: #ccc;"></i>
                    <h5 class="text-muted mt-3">No rooms found</h5>
                    <p class="text-muted">Click "Add New Room" to create your first study room</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(78, 115, 223, 0.05);
    }

    .btn-warning, .btn-danger {
        transition: all 0.3s;
        border: none;
        padding: 0.4rem 1rem;
    }

        .btn-warning:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.3);
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

    .badge {
        padding: 0.5rem 1rem;
        font-weight: 500;
    }
</style>