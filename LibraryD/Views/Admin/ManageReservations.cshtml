@model IEnumerable<LibraryD.Models.RoomReservation>
@{
    ViewData["Title"] = "Manage Reservations";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <!-- عنوان الصفحة -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-gradient-primary">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h2 class="mb-1 text-white">
                                <i class="bi bi-calendar-check-fill me-2"></i>
                                Manage Room Reservations
                            </h2>
                            <p class="mb-0 text-white-50">
                                <i class="bi bi-door-open me-1"></i>
                                Approve or reject room reservation requests from students
                            </p>
                        </div>
                        <div>
                            <span class="badge bg-white text-primary p-3 rounded-circle shadow-sm">
                                <i class="bi bi-door-open fs-3"></i>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- بطاقة الإحصائيات السريعة -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-warning bg-opacity-10 text-warning me-3">
                            <i class="bi bi-clock-history fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Pending Reservations</h6>
                            <h3 class="mb-0">@Model.Count(r => r.StatusId == 3)</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-success bg-opacity-10 text-success me-3">
                            <i class="bi bi-check-circle fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Confirmed Reservations</h6>
                            <h3 class="mb-0">@Model.Count(r => r.StatusId == 4)</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="avatar-circle bg-info bg-opacity-10 text-info me-3">
                            <i class="bi bi-door-open fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Total Rooms</h6>
                            <h3 class="mb-0">@ViewBag.TotalRooms</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- بطاقة الحجوزات -->
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-primary">
                    <i class="bi bi-list-ul me-2"></i>
                    All Room Reservations
                </h5>
                <div class="text-muted">
                    <i class="bi bi-calendar me-1"></i>
                    Total: @Model.Count()
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Room</th>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int counter = 1;
                        }
                        @foreach (var res in Model)
                        {
                            <tr>
                                <td>@counter</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-door-open text-primary me-2"></i>
                                        <strong>@(res.Room?.RoomName ?? "N/A")</strong>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle-sm bg-primary bg-opacity-10 text-primary me-2">
                                            @(res.User?.FirstName?.Length > 0 ? res.User.FirstName.Substring(0, 1).ToUpper() : "U")
                                        </div>
                                        <div>
                                            @(res.User?.FirstName ?? "Unknown") @(res.User?.LastName ?? "")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <small>
                                        <i class="bi bi-envelope text-muted me-1"></i>
                                        @(res.User?.Email ?? "N/A")
                                    </small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="bi bi-calendar3 me-1"></i>
                                        @res.ReservationDate.ToString("yyyy-MM-dd")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        <i class="bi bi-clock me-1"></i>
                                        @res.StartTime.ToString("HH:mm") - @res.EndTime.ToString("HH:mm")
                                    </span>
                                </td>
                                <td>
                                    @{
                                        string statusClass = res.StatusId == 3 ? "bg-warning text-dark" :
                                        res.StatusId == 4 ? "bg-success" :
                                        res.StatusId == 2 ? "bg-info" : "bg-secondary";

                                        string statusText = res.StatusId == 3 ? "Pending" :
                                        res.StatusId == 4 ? "Confirmed" :
                                        res.StatusId == 2 ? "Borrowed" : "Unknown";

                                        string statusIcon = res.StatusId == 3 ? "bi-clock-history" :
                                        res.StatusId == 4 ? "bi-check-circle" :
                                        res.StatusId == 2 ? "bi-door-open" : "bi-question-circle";
                                    }
                                    <span class="badge @statusClass">
                                        <i class="bi @statusIcon me-1"></i>
                                        @statusText
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (res.StatusId == 3) // Pending only
                                    {
                                        <div class="d-flex gap-2 justify-content-center">
                                            <form method="post" asp-action="ApproveReservation" asp-route-id="@res.ReservationId"
                                                  onsubmit="return confirm('Are you sure you want to APPROVE this reservation?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-success btn-sm" title="Approve">
                                                    <i class="bi bi-check-circle"></i> Approve
                                                </button>
                                            </form>
                                            <form method="post" asp-action="RejectReservation" asp-route-id="@res.ReservationId"
                                                  onsubmit="return confirm('Are you sure you want to REJECT this reservation?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm" title="Reject">
                                                    <i class="bi bi-x-circle"></i> Reject
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                            counter++;
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-door-open" style="font-size: 4rem; color: #ccc;"></i>
                        <h5 class="text-muted mt-3">No room reservations found</h5>
                        <p class="text-muted">When students reserve rooms, they will appear here</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ستايلات إضافية -->
<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
    }

    .stat-card {
        transition: all 0.3s;
        border-radius: 15px;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(78, 115, 223, 0.15) !important;
        }

    .avatar-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-circle-sm {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 14px;
    }

    .table > :not(caption) > * > * {
        padding: 1rem 0.75rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(78, 115, 223, 0.05);
    }

    .btn-success, .btn-danger {
        transition: all 0.3s;
        border: none;
        padding: 0.4rem 1rem;
    }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }

        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

    .badge {
        padding: 0.5rem 1rem;
        font-weight: 500;
    }
</style>